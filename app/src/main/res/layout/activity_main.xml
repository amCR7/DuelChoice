<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/background_game"
    android:fitsSystemWindows="true">

    <!-- Toolbar con botones de idioma -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="?attr/colorPrimary"
        android:elevation="4dp"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:title="DUEL CHOICE"
        app:titleTextAppearance="@style/ToolbarTitleStyle"
        app:titleTextColor="@android:color/white">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="end"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/btnIdiomaES"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="ES"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/boton_idioma"
                android:layout_marginEnd="4dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/btnIdiomaEN"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="EN"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/boton_idioma"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>
    </androidx.appcompat.widget.Toolbar>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="@dimen/margin_medium"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnPlay"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="@string/jugar_aleatorio"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:layout_margin="10dp"
            android:padding="12dp"
            android:background="@drawable/boton_play"
            android:elevation="8dp"
            android:foreground="?attr/selectableItemBackground"/>

        <Button
            android:id="@+id/btnChoose"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="@string/elegir_categoria"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:layout_margin="@dimen/margin_small"
            android:padding="12dp"
            android:background="@drawable/boton_choose"
            android:elevation="8dp"
            android:foreground="?attr/selectableItemBackground"/>

        <Button
            android:id="@+id/btnCreate"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="@string/crear_categoria"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:layout_margin="@dimen/margin_small"
            android:padding="12dp"
            android:background="@drawable/boton_create"
            android:elevation="8dp"
            android:foreground="?attr/selectableItemBackground"/>

    </LinearLayout>

</LinearLayout>
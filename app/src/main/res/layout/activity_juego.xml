<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/background_game"
    android:fitsSystemWindows="true">

    <!-- Toolbar -->
    <include layout="@layout/toolbar_default" />

    <FrameLayout
        android:id="@+id/containerOpcionA"
        android:layout_width="match_parent"
        android:layout_marginVertical="16dp"
        android:layout_height="0dp"
        android:layout_weight="3.5"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp" />

    <FrameLayout
        android:id="@+id/containerPregunta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="4dp" />

    <!-- Opción B (con margen horizontal) -->
    <FrameLayout
        android:id="@+id/containerOpcionB"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3.5"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp" />

    <!-- Botones -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="12dp"
        android:elevation="4dp">

        <Button
            android:id="@+id/btnFinalizar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/finalizar"
            android:background="@drawable/boton_cancel"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginEnd="8dp"
            android:elevation="4dp"/>

        <Button
            android:id="@+id/btnRanking"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/ranking"
            android:background="@drawable/boton_create"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"
            android:elevation="4dp"/>
    </LinearLayout>

</LinearLayout>